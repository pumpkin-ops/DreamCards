GITHUB_MODELS_TOKEN=github_pat_your_token
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
AI_TIMEOUT_MS=9000

AI_ALICE_MODEL=openai/gpt-4.1-mini
AI_BOB_MODEL=mistral-ai/mistral-small-2503
AI_CAROL_MODEL=microsoft/phi-4-multimodal-instruct

# Optional OpenAI-compatible image-to-image provider.
# Without these values, approved uploads use the local Sharp style fallback.
IMAGE_API_KEY=your_image_provider_key
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-1
IMAGE_REVIEW_MODEL=openai/gpt-4.1-mini
IMAGE_TIMEOUT_MS=45000
# Development only. Production should fail closed when visual moderation is unavailable.
IMAGE_ALLOW_LOCAL_REVIEW=false

AUTH_SECRET=replace-with-a-long-random-secret-for-production
