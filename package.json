{
  "name": "dreamcards",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "tsx watch backend/src/index.ts",
    "server:dev": "npm run backend:dev",
    "frontend:dev": "vite --host 0.0.0.0 --port 5173",
    "client:dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint \"frontend/src/**/*.{ts,tsx}\" \"backend/**/*.{ts,tsx}\" \"core/**/*.ts\" \"ai/**/*.ts\" \"examples/**/*.ts\" \"tests/**/*.ts\" \"api/**/*.ts\" vite.config.ts eslint.config.js",
    "test": "tsx --test tests/*.test.ts",
    "check": "npm run lint && npm test && npm run build",
    "start": "tsx backend/src/index.ts",
    "simulate:games": "tsc -p tsconfig.simulation.json && node .simulation-build/scripts/simulate-games.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "docx": "^9.7.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0"
  }
}
